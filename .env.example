# Copy to .env and adjust as needed.

# --- Database -----------------------------------------------------------------
# Local dev / tests default to SQLite (zero external services):
DATABASE_URL=sqlite:///./energy_matching.db
# Docker Compose / production example (PostgreSQL):
# DATABASE_URL=postgresql+psycopg://energy:energy@db:5432/energy_matching

# --- App ----------------------------------------------------------------------
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# --- Dashboard ----------------------------------------------------------------
# Base URL the Streamlit dashboard uses to reach the backend API.
API_BASE_URL=http://localhost:8000
